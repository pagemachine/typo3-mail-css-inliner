includes:
  - vendor/jangregor/phpstan-prophecy/extension.neon

parameters:
  level: 5

  paths:
    - ext_localconf.php
    - Classes
  excludePaths:
    - Classes/Mail/Mailer.php

  ignoreErrors:
    - message: '#Right side of || is always false.#'
      path: ext_localconf.php
      count: 1

  reportUnmatchedIgnoredErrors: false
